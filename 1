-- Nút toggle Black Screen (góc dưới phải)
local ToggleBlackBtn = Instance.new("TextButton")
ToggleBlackBtn.Size = UDim2.new(0, 50, 0, 50)
ToggleBlackBtn.Position = UDim2.new(1, -60, 1, -60)
ToggleBlackBtn.BackgroundTransparency = 1
