-- ================= NOTIFICATION =================
local function notify(title, text, dur)
    pcall(function() StarterGui:SetCore("SendNotification", { Title = title, Text = text, Duration = dur or 3 }) end)
end

-- ================= HSV TO RGB (RAINBOW) =================
local function HSVtoRGB(h, s, v)
    h = h % 1
    local r, g, b
    local i = math.floor(h * 6)
    local f = h * 6 - i
    local p = v * (1 - s)
    local q = v * (1 - f * s)
    local t = v * (1 - (1 - f) * s)
    i = i % 6
    if i == 0 then r, g, b = v, t, p
    elseif i == 1 then r, g, b = q, v, p
    elseif i == 2 then r, g, b = p, v, t
    elseif i == 3 then r, g, b = p, q, v
    elseif i == 4 then r, g, b = t, p, v
    elseif i == 5 then r, g, b = v, p, q
    end
    return Color3.new(r, g, b)
end

-- ================= AUTO CRASH MONITOR =================
task.spawn(function()
    while true do
        task.wait(5)
        if autoCrashEnabled then
            pcall(function()
                local mem = Stats:GetTotalMemoryUsageMb()
                if mem >= RAM_LIMIT_MB then
                    notify("⚠️ RAM LIMIT", string.format("%d/%d MB - Thoát sau 3s", mem, RAM_LIMIT_MB), 5)
                    task.wait(3)
                    game:Shutdown()
                end
            end)
        end
    end
end)

-- ================= FPS CONTROL =================
task.spawn(function()
    while true do
        pcall(function()
            if blackScreenEnabled then
                setfpscap(FPS_CAP)
            else
                setfpscap(60)
            end
        end)
        task.wait(1)
    end
end)

