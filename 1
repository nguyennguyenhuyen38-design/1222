ScreenGui.Name = "BlackScreenGui"
ScreenGui.ResetOnSpawn = false
ScreenGui.IgnoreGuiInset = true
ScreenGui.ZIndexBehavior = Enum.ZIndexBehavior.Sibling
ScreenGui.Parent = game.CoreGui

-- Black background (có thể ẩn/hiện)
local Background = Instance.new("Frame")
Background.Size = UDim2.new(1, 0, 1, 0)
Background.BackgroundColor3 = Color3.new(0, 0, 0)
Background.BorderSizePixel = 0
Background.BackgroundTransparency = 0
Background.Visible = blackScreenEnabled
Background.Parent = ScreenGui

-- InfoBar: thanh thông tin nằm trên cùng, NỀN TRONG SUỐT HOÀN TOÀN
local InfoBar = Instance.new("Frame")
InfoBar.Size = UDim2.new(0.98, 0, 0, 0)
InfoBar.Position = UDim2.new(0.5, 0, 0, 6)
InfoBar.AnchorPoint = Vector2.new(0.5, 0)
InfoBar.BackgroundColor3 = Color3.new(0, 0, 0)
InfoBar.BackgroundTransparency = 1.0          -- TRONG SUỐT 100%
InfoBar.BorderSizePixel = 0
InfoBar.AutomaticSize = Enum.AutomaticSize.Y
InfoBar.Parent = ScreenGui

-- UIListLayout để xếp hàng ngang, không wrap để tránh rối
local layout = Instance.new("UIListLayout", InfoBar)
layout.FillDirection = Enum.FillDirection.Horizontal
layout.HorizontalAlignment = Enum.HorizontalAlignment.Center
layout.VerticalAlignment = Enum.VerticalAlignment.Center
layout.Padding = UDim.new(0, 6)
layout.Wraps = false               -- Không xuống dòng

-- Hàm tạo Label (chữ thường, nền trong suốt)
local function createLabel(text, color)
    local lbl = Instance.new("TextLabel")
    lbl.BackgroundTransparency = 1
    lbl.BorderSizePixel = 0
    lbl.Text = text
    lbl.TextColor3 = color or Color3.new(1,1,1)
    lbl.Font = Enum.Font.FredokaOne
    lbl.TextSize = 18
    lbl.Size = UDim2.new(0, 0, 0, 24)
    lbl.AutomaticSize = Enum.AutomaticSize.X
    lbl.TextXAlignment = Enum.TextXAlignment.Left
    lbl.Parent = InfoBar
    return lbl
end

-- Hàm tạo Button (nền trong suốt, chỉ đổi màu chữ khi hover)
local function createButton(text, color)
    local btn = Instance.new("TextButton")
    btn.BackgroundTransparency = 1          -- NỀN TRONG SUỐT
    btn.BorderSizePixel = 0
    btn.Text = text
    btn.TextColor3 = color or Color3.new(1,1,1)
    btn.Font = Enum.Font.FredokaOne
    btn.TextSize = 18
    btn.Size = UDim2.new(0, 0, 0, 24)
    btn.AutomaticSize = Enum.AutomaticSize.X
    btn.TextXAlignment = Enum.TextXAlignment.Center
    btn.Parent = InfoBar
    
    -- Hiệu ứng hover: đổi màu nhẹ
    btn.MouseEnter:Connect(function()
        btn.TextColor3 = Color3.new(0.8, 0.8, 1)
    end)
    btn.MouseLeave:Connect(function()
        -- khôi phục màu gốc sẽ do update loop xử lý, nhưng ta lưu màu gốc vào thuộc tính
        -- Sẽ update sau, tạm thời để màu trắng
    end)
    return btn
end

-- ========== TẠO CÁC THÀNH PHẦN THEO ĐÚNG THỨ TỰ ==========
local usernameLabel = createLabel(LocalPlayer.Name)

local sep1 = createLabel("|")

local crashPrefix = createLabel("⚠️ Auto crash:")  -- Dùng emoji warning

local crashToggle = createButton("On")              -- Sẽ cập nhật trạng thái sau

local ramDisplay = createButton("0/2500")           -- Hiển thị RAM

local sep2 = createLabel("|")

local fpsToggle = createButton("FPS:")              -- Nút bật/tắt FPS lock

local fpsValue = createLabel("0")                   -- Giá trị FPS hiện tại

local lockPrefix = createLabel("(Lock cap:")

local lockCap = createButton(tostring(fpsCapValue)) -- Nút đặt FPS cap

local lockSuffix = createLabel(")")

local sep3 = createLabel("|")

local pingPrefix = createLabel("Ping:")

local pingValue = createLabel("0")

-- Lưu trữ để cập nhật dễ dàng
local uiElements = {
    crashToggle = crashToggle,
    ramDisplay = ramDisplay,
    fpsToggle = fpsToggle,
    fpsValue = fpsValue,
    lockCap = lockCap,
    pingValue = pingValue,
    labels = { usernameLabel, sep1, crashPrefix, sep2, lockPrefix, lockSuffix, sep3, pingPrefix }
}

-- ========== NÚT BẬT/TẮT MÀN HÌNH ĐEN (GÓC DƯỚI PHẢI) ==========
local ToggleBlackBtn = Instance.new("TextButton")
ToggleBlackBtn.Size = UDim2.new(0, 50, 0, 50)
ToggleBlackBtn.Position = UDim2.new(1, -60, 1, -60)
ToggleBlackBtn.BackgroundTransparency = 1
ToggleBlackBtn.TextScaled = true
ToggleBlackBtn.RichText = true
ToggleBlackBtn.Text = blackScreenEnabled and '<font color="rgb(0,255,0)">></font>' or '<font color="rgb(255,0,0)">X</font>'
ToggleBlackBtn.Parent = ScreenGui

ToggleBlackBtn.MouseButton1Click:Connect(function()
    blackScreenEnabled = not blackScreenEnabled
    config.blackScreenEnabled = blackScreenEnabled
    saveConfig()
    Background.Visible = blackScreenEnabled
    ToggleBlackBtn.Text = blackScreenEnabled and '<font color="rgb(0,255,0)">></font>' or '<font color="rgb(255,0,0)">X</font>'
    notify("Black Screen", blackScreenEnabled and "BẬT" or "TẮT", 2)
end)

-- ========== XỬ LÝ TƯƠNG TÁC ==========
crashToggle.MouseButton1Click:Connect(function()
    autoShutdownEnabled = not autoShutdownEnabled
    config.autoCrashEnabled = autoShutdownEnabled
    saveConfig()
    notify("Auto Crash", autoShutdownEnabled and "BẬT" or "TẮT", 2)
end)

ramDisplay.MouseButton1Click:Connect(function()
    local box = Instance.new("TextBox")
    box.Size = UDim2.new(0, 120, 0, 30)
    box.Position = UDim2.new(0.5, -60, 0.5, -15)
    box.PlaceholderText = "RAM limit (MB)"
    box.Text = tostring(memoryLimitMB)
    box.Parent = ScreenGui
    box:CaptureFocus()
    box.FocusLost:Connect(function(enter)
        local val = tonumber(box.Text)
        if val and val >= 500 then
            memoryLimitMB = val
            config.ramLimit = val
            saveConfig()
            notify("RAM Limit", "Đã đặt "..val.." MB", 2)
        else
            notify("Lỗi", "Giá trị >=500", 2)
        end
        box:Destroy()
    end)
end)

lockCap.MouseButton1Click:Connect(function()
    local box = Instance.new("TextBox")
    box.Size = UDim2.new(0, 80, 0, 30)
    box.Position = UDim2.new(0.5, -40, 0.5, -15)
    box.PlaceholderText = "FPS Cap (5-60)"
    box.Text = tostring(fpsCapValue)
    box.Parent = ScreenGui
    box:CaptureFocus()
    box.FocusLost:Connect(function(enter)
        local val = tonumber(box.Text)
        if val and val >= 5 and val <= 60 then
            fpsCapValue = val
            config.fpsCap = val
            saveConfig()
            notify("FPS Cap", "Đã đặt "..val.." FPS", 2)
        else
            notify("Lỗi", "Giá trị 5-60", 2)
        end
        box:Destroy()
    end)
end)

fpsToggle.MouseButton1Click:Connect(function()
    fpsLockEnabled = not fpsLockEnabled
    config.fpsLockEnabled = fpsLockEnabled
    saveConfig()
    notify("FPS Lock", fpsLockEnabled and "BẬT (cap "..fpsCapValue..")" or "TẮT (60 FPS)", 2)
end)

-- ========== CẬP NHẬT ĐỘNG ==========
local fps = 0
local lastTime = tick()
local frameCount = 0

RunService.RenderStepped:Connect(function(dt)
    frameCount = frameCount + 1
    local now = tick()
    if now - lastTime >= 1 then
        fps = frameCount
        frameCount = 0
        lastTime = now
    end

    local mem = math.floor(Stats:GetTotalMemoryUsageMb())
    local ping = math.floor(LocalPlayer:GetNetworkPing() * 1000)

    -- Cập nhật text
    crashToggle.Text = autoShutdownEnabled and "On" or "Off"
    crashToggle.TextColor3 = autoShutdownEnabled and Color3.new(0,1,0) or Color3.new(1,0,0)
    
    ramDisplay.Text = string.format("%d/%d", mem, memoryLimitMB)
    fpsValue.Text = tostring(fps)
    lockCap.Text = tostring(fpsCapValue)
    pingValue.Text = tostring(ping)

    -- Màu cho nút FPS toggle (xanh nếu lock, trắng nếu tắt)
    fpsToggle.TextColor3 = fpsLockEnabled and Color3.new(0,1,0) or Color3.new(1,1,1)

    -- Responsive font size (giữ nguyên)
    local screenWidth = workspace.CurrentCamera.ViewportSize.X
    local baseSize = math.clamp(math.floor(screenWidth * 0.014), 14, 24)
    for _, elem in pairs(uiElements.labels) do 
        elem.TextSize = baseSize 
    end
    crashToggle.TextSize = baseSize
    ramDisplay.TextSize = baseSize
    fpsToggle.TextSize = baseSize
    fpsValue.TextSize = baseSize
    lockCap.TextSize = baseSize
    pingValue.TextSize = baseSize

    -- Hiệu ứng cầu vồng
    if rainbowEnabled then
        local hue = (tick() % rainbowSpeed) / rainbowSpeed
        local color = HSVtoRGB(hue, 0.9, 1.0)
        for _, elem in pairs(uiElements.labels) do 
            elem.TextColor3 = color 
        end
        ramDisplay.TextColor3 = color
        fpsValue.TextColor3 = color
        lockCap.TextColor3 = color
        pingValue.TextColor3 = color
        -- fpsToggle và crashToggle giữ màu riêng (không cầu vồng)
    else
        local white = Color3.new(1,1,1)
        for _, elem in pairs(uiElements.labels) do 
            elem.TextColor3 = white 
        end
        ramDisplay.TextColor3 = white
        fpsValue.TextColor3 = white
        lockCap.TextColor3 = white
        pingValue.TextColor3 = white
        fpsToggle.TextColor3 = fpsLockEnabled and Color3.new(0,1,0) or white
    end
end)

-- ================= LOAD EXTERNAL SCRIPT =================
local function safeLoad(url, name)
    pcall(function()
        local success, result = pcall(game.HttpGet, game, url)
        if success then
            local f = loadstring(result)
            if f then pcall(f) end
        end
    end)
end

