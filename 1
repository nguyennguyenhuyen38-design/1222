-- ================= CONFIG LOADER (TỰ ĐỘNG LƯU CẤU HÌNH) =================
local CONFIG_FILE = "BlackScreen_Config.json"
local config = {
    autoCrashEnabled = true,
    ramLimit = 2500,
    fpsCap = 10,
    rainbowSpeed = 3.0,  -- mặc định chậm hơn
    rainbowEnabled = true
}

-- Hàm đọc config từ file (nếu executor hỗ trợ)
local function loadConfig()
    pcall(function()
        if readfile and writefile then
            local content = readfile(CONFIG_FILE)
            if content then
                local saved = game:GetService("HttpService"):JSONDecode(content)
                for k,v in pairs(saved) do
                    config[k] = v
                end
            end
        end
    end)
end
loadConfig()

-- Hàm lưu config
local function saveConfig()
    pcall(function()
        if writefile then
            writefile(CONFIG_FILE, game:GetService("HttpService"):JSONEncode(config))
        end
    end)
end

-- ================= CÁC BIẾN GLOBAL =================
local fpsLockEnabled = true
local autoShutdownEnabled = config.autoCrashEnabled
local memoryLimitMB = config.ramLimit
local fpsCapValue = config.fpsCap
local rainbowSpeed = config.rainbowSpeed
local rainbowEnabled = config.rainbowEnabled
local shutdownCheckInterval = 5

-- ================= SERVICES =================
local Players = game:GetService("Players")
local RunService = game:GetService("RunService")
local Stats = game:GetService("Stats")
local StarterGui = game:GetService("StarterGui")
local UserInputService = game:GetService("UserInputService")
local LocalPlayer = Players.LocalPlayer

-- ================= PHÁT HIỆN THIẾT BỊ =================
local function getDeviceType()
    local platform = UserInputService:GetPlatform()
    if platform == Enum.Platform.Windows or platform == Enum.Platform.OSX or platform == Enum.Platform.Linux then
        return "PC"
    elseif platform == Enum.Platform.Android or platform == Enum.Platform.IOS then
        return "Mobile"
    else
        return "Other"
    end
end
local deviceType = getDeviceType()

-- ================= SAFE LOAD FUNCTION =================
local function safeLoad(url, name)
    local success, result = pcall(function()
        return game:HttpGet(url)
    end)
    if not success then
        warn("[ERROR] Không load được: " .. name)
        return
    end
    local func = loadstring(result)
    if not func then
        warn("[ERROR] Lỗi loadstring: " .. name)
        return
    end
    pcall(func)
end

-- ================= NOTIFY =================
local function notify(title, text, duration)
    pcall(function()
        StarterGui:SetCore("SendNotification", {
            Title = title,
            Text = text,
            Duration = duration or 3
        })
    end)
end

-- ================= AUTO SHUTDOWN MONITOR =================
task.spawn(function()
    while true do
        task.wait(shutdownCheckInterval)
        if autoShutdownEnabled then
            pcall(function()
                local currentMem = Stats:GetTotalMemoryUsageMb()
                if currentMem >= memoryLimitMB then
                    notify("⚠️ CẢNH BÁO RAM", string.format("%d/%d MB - Tự thoát sau 3s", currentMem, memoryLimitMB), 5)
                    task.wait(3)
                    game:Shutdown()
                end
            end)
        end
    end
end)

-- ================= FPS CONTROL =================
task.spawn(function()
    while true do
        pcall(function()
            if fpsLockEnabled then
                setfpscap(fpsCapValue)
            else
                setfpscap(60)
            end
        end)
        task.wait(1)
    end
end)

-- ================= HSV TO RGB (CẦU VỒNG) =================
local function HSVtoRGB(h, s, v)
    h = h % 1
    local r, g, b
    local i = math.floor(h * 6)
    local f = h * 6 - i
    local p = v * (1 - s)
    local q = v * (1 - f * s)
    local t = v * (1 - (1 - f) * s)
    i = i % 6
    if i == 0 then r, g, b = v, t, p
    elseif i == 1 then r, g, b = q, v, p
    elseif i == 2 then r, g, b = p, v, t
    elseif i == 3 then r, g, b = p, q, v
    elseif i == 4 then r, g, b = t, p, v
    elseif i == 5 then r, g, b = v, p, q
    end
    return Color3.new(r, g, b)
end

