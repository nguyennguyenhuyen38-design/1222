-- ================= CẬP NHẬT DỮ LIỆU LIÊN TỤC =================
local fps = 0
local lastTime = tick()
local frameCount = 0

RunService.RenderStepped:Connect(function(deltaTime)
    frameCount = frameCount + 1
    local now = tick()
    if now - lastTime >= 1 then
        fps = frameCount
        frameCount = 0
        lastTime = now
    end
    
    local mem = math.floor(Stats:GetTotalMemoryUsageMb())
    local ping = math.floor(LocalPlayer:GetNetworkPing() * 1000)
    
    -- Cập nhật text
    crashToggle.Text = autoShutdownEnabled and "On" or "Off"
    crashToggle.TextColor3 = autoShutdownEnabled and Color3.new(0,1,0) or Color3.new(1,0,0)
    ramDisplay.Text = string.format("%d/%d MB", mem, memoryLimitMB)
    fpsValue.Text = tostring(fps)
    lockCap.Text = tostring(fpsCapValue)
    pingValue.Text = ping .. " ms"
    
    -- Hiệu ứng cầu vồng (áp dụng cho tất cả label và button trừ crashToggle)
    if rainbowEnabled then
        local hue = (tick() % rainbowSpeed) / rainbowSpeed
        local color = HSVtoRGB(hue, 0.9, 1.0)
        for _, elem in pairs(uiElements) do
            if elem ~= crashToggle then
                elem.TextColor3 = color
            end
        end
        -- Cập nhật cả các label không nằm trong uiElements (sep, prefix...)
        -- Duyệt tất cả con của TopBar
        for _, child in ipairs(TopBar:GetChildren()) do
            if child:IsA("TextLabel") or (child:IsA("TextButton") and child ~= crashToggle and child ~= ramDisplay and child ~= lockCap) then
                child.TextColor3 = color
            end
        end
    else
        local defaultColor = Color3.new(1,1,1)
        for _, elem in pairs(uiElements) do
            if elem ~= crashToggle then
                elem.TextColor3 = defaultColor
            end
        end
        for _, child in ipairs(TopBar:GetChildren()) do
            if (child:IsA("TextLabel") or child:IsA("TextButton")) and child ~= crashToggle then
                child.TextColor3 = defaultColor
            end
        end
    end
end)

