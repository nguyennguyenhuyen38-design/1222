local function createTextButton(parent, name, initialText, position, size)
    local btn = Instance.new("TextButton")
    btn.Name = name
    btn.BackgroundTransparency = 1
    btn.Text = initialText
    btn.TextColor3 = Color3.new(1, 1, 1)
    btn.TextSize = 24
    btn.FontFace = Font.fromName("FredokaOne", Enum.FontWeight.Bold)
    btn.TextXAlignment = Enum.TextXAlignment.Center
    btn.TextYAlignment = Enum.TextYAlignment.Center
    btn.Size = size or UDim2.new(0, 0, 1, 0)
    btn.Position = position
    btn.Parent = parent
    btn.RichText = false
    btn.TextTruncate = Enum.TextTruncate.None
    btn.TextScaled = false
    btn.AutomaticSize = Enum.AutomaticSize.X
    return btn
end

