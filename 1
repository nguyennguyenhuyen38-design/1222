end)

ramDisplay.MouseButton1Click:Connect(function()
    local inputBox = Instance.new("TextBox")
    inputBox.Size = UDim2.new(0, 120, 0, 30)
    inputBox.Position = UDim2.new(0.5, -60, 0.5, -15)
    inputBox.PlaceholderText = "RAM limit (MB)"
    inputBox.Text = tostring(memoryLimitMB)
    inputBox.Parent = ScreenGui
    inputBox:CaptureFocus()
    inputBox.FocusLost:Connect(function(enterPressed)
        local val = tonumber(inputBox.Text)
        if val and val >= 500 then
            memoryLimitMB = val
            config.ramLimit = val
            saveConfig()
            notify("RAM Limit", "Đã đặt "..val.." MB", 2)
        else
            notify("Lỗi", "Giá trị không hợp lệ (>=500)", 2)
        end
        inputBox:Destroy()
    end)
end)

