-- ================= FPS / PING / RAM DISPLAY (CÓ RAINBOW) =================
local fps = 0
local last = tick()
local frames = 0
local hueShift = 0

RunService.RenderStepped:Connect(function(deltaTime)
    frames = frames + 1
    local now = tick()
    if now - last >= 1 then
        fps = frames
        frames = 0
        last = now
    end
    
    if fpsLockEnabled then
        local mem = math.floor(Stats:GetTotalMemoryUsageMb())
        local ping = math.floor(LocalPlayer:GetNetworkPing() * 1000)
        
        local textColor
        if rainbowTextEnabled then
            hueShift = (hueShift + deltaTime / rainbowSpeed) % 1
            textColor = HSVtoRGB(hueShift, 0.9, 1.0)
        else
            if mem >= memoryLimitMB * 0.9 then
                textColor = Color3.new(1, 0.3, 0.3)
            else
                textColor = Color3.new(1, 1, 1)
            end
        end
        
        Label.TextColor3 = textColor
        Label.Text = "FPS: " .. fps .. "\nPING: " .. ping .. " ms\nRAM: " .. mem .. " MB"
        
        if not rainbowTextEnabled and mem >= memoryLimitMB * 0.9 then
            Label.TextColor3 = Color3.new(1, 0.2, 0.2)
        end
    end
end)

