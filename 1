-- Hàm tạo TextButton với tự động scale theo kích thước màn hình
local function createScaledTextButton(parent, name, initialText, positionScale)
    local btn = Instance.new("TextButton")
    btn.Name = name
    btn.BackgroundTransparency = 1
    btn.Text = initialText
    btn.TextColor3 = Color3.new(1, 1, 1)
    btn.FontFace = Font.fromName("FredokaOne", Enum.FontWeight.Bold)
    btn.TextXAlignment = Enum.TextXAlignment.Left
    btn.TextYAlignment = Enum.TextYAlignment.Center
    btn.Position = UDim2.new(positionScale, 0, 0, 0)
    btn.Size = UDim2.new(0, 0, 1, 0)  -- chiều cao full, chiều rộng tự động
    btn.AutomaticSize = Enum.AutomaticSize.X
    btn.TextScaled = true  -- tự động scale chữ theo kích thước nút
    btn.Parent = parent
    btn.RichText = false
    return btn
end

