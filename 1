ToggleBlackBtn.Parent = ScreenGui

ToggleBlackBtn.MouseButton1Click:Connect(function()
    blackScreenEnabled = not blackScreenEnabled
    Background.Visible = blackScreenEnabled
    ToggleBlackBtn.Text = blackScreenEnabled and '<font color="rgb(0,255,0)">></font>' or '<font color="rgb(255,0,0)">X</font>'
    notify("Black Screen", blackScreenEnabled and "BẬT (FPS "..FPS_CAP..")" or "TẮT (FPS 60)", 2)
end)

-- ================= CẬP NHẬT DỮ LIỆU =================
local fps = 0
local lastTime = tick()
local frameCount = 0

RunService.RenderStepped:Connect(function(dt)
    frameCount = frameCount + 1
    local now = tick()
    if now - lastTime >= 1 then
        fps = frameCount
        frameCount = 0
        lastTime = now
    end

    local mem = math.floor(Stats:GetTotalMemoryUsageMb())
    local ping = math.floor(LocalPlayer:GetNetworkPing() * 1000)

    -- Cập nhật text
    ramLabel.Text = string.format("%d/%d MB", mem, RAM_LIMIT_MB)
    fpsLabel.Text = "FPS: " .. tostring(fps)
    pingLabel.Text = "Ping: " .. tostring(ping)

    -- Font size thích ứng (lớn hơn chút)
    local screenWidth = workspace.CurrentCamera.ViewportSize.X
    local baseSize = math.clamp(math.floor(screenWidth * 0.2), 20, 40)
    for _, lbl in ipairs(uiLabels) do lbl.TextSize = baseSize end

    -- Hiệu ứng cầu vồng
    if RAINBOW_ENABLED then
        local hue = (tick() % RAINBOW_SPEED) / RAINBOW_SPEED
        local color = HSVtoRGB(hue, 0.9, 1.0)
        for _, lbl in ipairs(uiLabels) do lbl.TextColor3 = color end
    else
        local white = Color3.new(1,1,1)
        for _, lbl in ipairs(uiLabels) do lbl.TextColor3 = white end
    end
end)

