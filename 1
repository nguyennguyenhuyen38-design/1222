-- Sắp xếp vị trí theo thứ tự trong InfoContainer
local function arrangeElements()
    local xPos = 0
    local spacing = 4
    local elements = {
        usernameLabel, sep1, deviceLabel, sep2, crashPrefix, crashToggle, paren1,
        ramDisplay, paren2, sep3, fpsPrefix, fpsValueLabel, lockPrefix, lockCapValue,
        lockSuffix, sep4, pingPrefix, pingValueLabel
    }
    for _, elem in ipairs(elements) do
        elem.Position = UDim2.new(0, xPos, 0, 0)
        xPos = xPos + elem.TextBounds.X + spacing
    end
end

-- Hàm cập nhật text cho các thành phần động
local function updateUI()
    local mem = math.floor(Stats:GetTotalMemoryUsageMb())
    local ping = math.floor(LocalPlayer:GetNetworkPing() * 1000)
    
    crashToggle.Text = autoShutdownEnabled and "On" or "Off"
    crashToggle.TextColor3 = autoShutdownEnabled and Color3.new(0, 1, 0) or Color3.new(1, 0, 0)
    ramDisplay.Text = string.format("%d/%d MB", mem, memoryLimitMB)
    fpsValueLabel.Text = tostring(fps)
    lockCapValue.Text = tostring(fpsCapValue)
    pingValueLabel.Text = ping .. " ms"
    
    -- Cập nhật màu sắc cho tất cả (nếu cầu vồng bật)
    if rainbowEnabled then
        local hue = (tick() % rainbowSpeed) / rainbowSpeed
        local color = HSVtoRGB(hue, 0.9, 1.0)
        for _, elem in pairs(uiElements) do
            if elem:IsA("TextButton") then
                -- Giữ màu riêng cho crashToggle
                if elem == crashToggle then
                    -- giữ nguyên
                else
                    elem.TextColor3 = color
                end
            end
        end
    else
        local defaultColor = Color3.new(1, 1, 1)
        for _, elem in pairs(uiElements) do
            if elem ~= crashToggle then
                elem.TextColor3 = defaultColor
            end
        end
    end
    
    arrangeElements()
end

