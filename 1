    btn.FontFace = Font.fromName("FredokaOne", Enum.FontWeight.Bold)
    btn.TextScaled = true
    btn.Size = UDim2.new(0, 0, 0.7, 0)  -- chiều cao 70% thanh
    btn.AutomaticSize = Enum.AutomaticSize.X
    btn.TextXAlignment = Enum.TextXAlignment.Center
    btn.Parent = TopBar
    
    local corner = Instance.new("UICorner")
    corner.CornerRadius = UDim.new(0, 8)
    corner.Parent = btn
    
