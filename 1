local function createLabel(text)
    local lbl = Instance.new("TextLabel")
    lbl.BackgroundTransparency = 1
    lbl.Text = text
    lbl.TextColor3 = Color3.new(1,1,1)
    lbl.FontFace = Font.fromName("FredokaOne", Enum.FontWeight.Bold)
    lbl.TextSize = 18
    lbl.Size = UDim2.new(0, 0, 1, -4)
    lbl.AutomaticSize = Enum.AutomaticSize.X
    lbl.TextXAlignment = Enum.TextXAlignment.Left
    lbl.Parent = InfoBar
    return lbl
end

local function createIconButton()
    local btn = Instance.new("TextButton")
    btn.BackgroundColor3 = Color3.new(0.15, 0.15, 0.15)
    btn.BorderSizePixel = 0
    btn.Text = ""
    btn.RichText = true
    btn.TextColor3 = Color3.new(1,1,1)
    btn.FontFace = Font.fromName("FredokaOne", Enum.FontWeight.Bold)
    btn.TextSize = 18
    btn.Size = UDim2.new(0, 30, 0.8, 0)
    btn.AutomaticSize = Enum.AutomaticSize.X
    btn.TextXAlignment = Enum.TextXAlignment.Center
    btn.Parent = InfoBar
    Instance.new("UICorner", btn).CornerRadius = UDim.new(0, 8)
