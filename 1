-- ================= CẬP NHẬT DỮ LIỆU & HIỆU ỨNG =================
local fps = 0
local lastTime = tick()
local frameCount = 0

RunService.RenderStepped:Connect(function(dt)
    frameCount = frameCount + 1
    local now = tick()
    if now - lastTime >= 1 then
        fps = frameCount
        frameCount = 0
        lastTime = now
    end

    local mem = math.floor(Stats:GetTotalMemoryUsageMb())
    local ping = math.floor(LocalPlayer:GetNetworkPing() * 1000)

    crashIcon.Text = autoCrashEnabled and '<font color="#00FF00">✅</font>' or '<font color="#FF0000">❌</font>'
    ramLabel.Text = string.format("%d/%d", mem, RAM_LIMIT_MB)
    fpsValue.Text = tostring(fps)
    pingValue.Text = tostring(ping)

    local screenWidth = workspace.CurrentCamera.ViewportSize.X
    local baseSize = math.clamp(math.floor(screenWidth * 0.016), 18, 28)
    for _, lbl in ipairs(statusLabels) do lbl.TextSize = baseSize end
    crashIcon.TextSize = baseSize
    ramLabel.TextSize = baseSize
    fpsValue.TextSize = baseSize
    pingValue.TextSize = baseSize

    if RAINBOW_ENABLED then
        local hue = (tick() % RAINBOW_SPEED) / RAINBOW_SPEED
        local color = HSVtoRGB(hue, 0.9, 1.0)
        for _, lbl in ipairs(statusLabels) do lbl.TextColor3 = color end
        ramLabel.TextColor3 = color
        fpsValue.TextColor3 = color
        pingValue.TextColor3 = color
        accountLabel.TextColor3 = color
        discordLabel.TextColor3 = color
    else
        local white = Color3.new(1,1,1)
        for _, lbl in ipairs(statusLabels) do lbl.TextColor3 = white end
        ramLabel.TextColor3 = white
        fpsValue.TextColor3 = white
        pingValue.TextColor3 = white
        accountLabel.TextColor3 = white
        discordLabel.TextColor3 = white
    end
end)

