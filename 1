local function createParticle(position, color)
    local p = Instance.new("Frame")
    p.Size = UDim2.new(0, math.random(5, 10), 0, math.random(5, 10))
    p.AnchorPoint = Vector2.new(0.5, 0.5)
    p.Position = position
    p.BackgroundColor3 = color
    p.BorderSizePixel = 0
    p.ZIndex = 15
    p.Parent = ParticleLayer

    local pc = Instance.new("UICorner")
    pc.CornerRadius = UDim.new(1, 0)
    pc.Parent = p
    return p
end

local function burstTransition(fromPos, toPos, pieceCount, duration)
    for _ = 1, pieceCount do
        local particle = createParticle(fromPos, Color3.fromRGB(math.random(120, 255), 255, math.random(120, 255)))
        local midOffset = Vector2.new(math.random(-140, 140), math.random(-110, 110))
        local endOffset = Vector2.new(math.random(-24, 24), math.random(-24, 24))
        local midPos = UDim2.new(toPos.X.Scale, toPos.X.Offset + midOffset.X, toPos.Y.Scale, toPos.Y.Offset + midOffset.Y)
        local endPos = UDim2.new(toPos.X.Scale, toPos.X.Offset + endOffset.X, toPos.Y.Scale, toPos.Y.Offset + endOffset.Y)

        local tweenA = TweenService:Create(
            particle,
            TweenInfo.new(duration * 0.45, Enum.EasingStyle.Quad, Enum.EasingDirection.Out),
            {Position = midPos, BackgroundTransparency = 0.25}
        )
        local tweenB = TweenService:Create(
            particle,
            TweenInfo.new(duration * 0.55, Enum.EasingStyle.Quad, Enum.EasingDirection.In),
            {Position = endPos, BackgroundTransparency = 1, Size = UDim2.new(0, 2, 0, 2)}
        )
        tweenA:Play()
        tweenA.Completed:Connect(function()
            tweenB:Play()
        end)
        tweenB.Completed:Connect(function()
            particle:Destroy()
        end)
    end
end

local transitionBusy = false
local function toggleBlackScreen()
    if transitionBusy then return end
    transitionBusy = true

    blackScreenEnabled = not blackScreenEnabled
    Background.Visible = blackScreenEnabled

    local centerPos = UDim2.new(0.5, 0, 0.5, 0)
    local logoPos = LogoButton.Position

    if blackScreenEnabled then
        -- Logo tan mảnh, gom thành nội dung giữa màn hình
        CenterFrame.Visible = true
        for _, obj in ipairs(centerTextObjects) do
            obj.TextTransparency = 1
        end
        stroke.Transparency = 1
        burstTransition(logoPos, centerPos, 38, 0.55)
        tweenCenterContent(0, 0.45)
        TweenService:Create(LogoButton, TweenInfo.new(0.2), {ImageTransparency = 0.15, BackgroundTransparency = 0.4}):Play()
        task.wait(0.5)
        LogoButton.ImageTransparency = 0
        LogoButton.BackgroundTransparency = 0.25
    else
        -- Nội dung giữa màn hình tan mảnh, gom lại thành logo
        LogoButton.ImageTransparency = 1
        LogoButton.BackgroundTransparency = 1
        burstTransition(centerPos, logoPos, 38, 0.55)
        TweenService:Create(LogoButton, TweenInfo.new(0.45, Enum.EasingStyle.Sine, Enum.EasingDirection.Out), {ImageTransparency = 0, BackgroundTransparency = 0.25}):Play()
        tweenCenterContent(1, 0.2)
        task.wait(0.25)
        CenterFrame.Visible = false
        for _, obj in ipairs(centerTextObjects) do
            obj.TextTransparency = 0
        end
        stroke.Transparency = 0
    end

    notify("Black Screen", blackScreenEnabled and "✅ BẬT (FPS "..FPS_CAP..")" or "✅ TẮT (FPS 60)", 2, LOGO_IMAGE_ID)
    transitionBusy = false
end

LogoButton.MouseButton1Click:Connect(function()
