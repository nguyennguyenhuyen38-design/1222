-- ================= CONFIG (CHỈNH SỬA TRỰC TIẾP TRONG SCRIPT) =================
local RAM_LIMIT_MB = 2500               -- Giới hạn RAM để auto crash (MB)
local FPS_CAP = 10                      -- Mức giới hạn FPS khi black screen bật
local RAINBOW_ENABLED = true            -- Hiệu ứng cầu vồng cho chữ
local RAINBOW_SPEED = 3.0               -- Tốc độ chuyển màu (giây)
local AUTO_CRASH_ENABLED = true         -- Bật/tắt auto crash (chỉ sửa ở đây, không tương tác UI)

-- ================= SERVICES =================
local Players = game:GetService("Players")
local RunService = game:GetService("RunService")
local Stats = game:GetService("Stats")
local StarterGui = game:GetService("StarterGui")
local LocalPlayer = Players.LocalPlayer

-- ================= STATE =================
local blackScreenEnabled = true          -- Mặc định bật
local autoCrashEnabled = AUTO_CRASH_ENABLED

-- ================= UTILS =================
local function notify(title, text, dur)
    pcall(function() StarterGui:SetCore("SendNotification", { Title = title, Text = text, Duration = dur or 3 }) end)
end

local function HSVtoRGB(h, s, v)
    h = h % 1
    local r, g, b
    local i = math.floor(h * 6)
    local f = h * 6 - i
    local p = v * (1 - s)
    local q = v * (1 - f * s)
    local t = v * (1 - (1 - f) * s)
    i = i % 6
    if i == 0 then r, g, b = v, t, p
    elseif i == 1 then r, g, b = q, v, p
    elseif i == 2 then r, g, b = p, v, t
    elseif i == 3 then r, g, b = p, q, v
    elseif i == 4 then r, g, b = t, p, v
    elseif i == 5 then r, g, b = v, p, q
    end
    return Color3.new(r, g, b)
end

-- ================= AUTO CRASH MONITOR =================
task.spawn(function()
    while true do
        task.wait(5)
        if autoCrashEnabled then
            pcall(function()
                local mem = Stats:GetTotalMemoryUsageMb()
                if mem >= RAM_LIMIT_MB then
                    notify("⚠️ RAM LIMIT", string.format("%d/%d MB - Thoát sau 3s", mem, RAM_LIMIT_MB), 5)
                    task.wait(3)
                    game:Shutdown()
                end
            end)
        end
    end
end)

-- ================= FPS CONTROL (chỉ hoạt động khi black screen bật) =================
task.spawn(function()
    while true do
        pcall(function()
            if blackScreenEnabled then
                setfpscap(FPS_CAP)
            else
                setfpscap(60)
            end
        end)
        task.wait(1)
    end
end)

