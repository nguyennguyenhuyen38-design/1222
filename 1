-- ================= CẬP NHẬT DỮ LIỆU LIÊN TỤC =================
local fps = 0
local lastTime = tick()
local frameCount = 0

RunService.RenderStepped:Connect(function(deltaTime)
    frameCount = frameCount + 1
    local now = tick()
    if now - lastTime >= 1 then
        fps = frameCount
        frameCount = 0
        lastTime = now
    end
    
    local mem = math.floor(Stats:GetTotalMemoryUsageMb())
    local ping = math.floor(LocalPlayer:GetNetworkPing() * 1000)
    
    -- Cập nhật text
    elements.crashToggle.Text = autoShutdownEnabled and "On" or "Off"
    elements.crashToggle.TextColor3 = autoShutdownEnabled and Color3.new(0,1,0) or Color3.new(1,0,0)
    elements.ramDisplay.Text = string.format("%d/%d MB", mem, memoryLimitMB)
    elements.fpsValue.Text = tostring(fps)
    elements.lockCap.Text = tostring(fpsCapValue)
    elements.pingValue.Text = ping .. " ms"
    
    -- Hiệu ứng cầu vồng
    if rainbowEnabled then
        local hue = (tick() % rainbowSpeed) / rainbowSpeed
        local color = HSVtoRGB(hue, 0.9, 1.0)
        for _, elem in pairs(elements) do
            if elem:IsA("TextButton") and elem ~= elements.crashToggle then
                elem.TextColor3 = color
            end
        end
    else
        for _, elem in pairs(elements) do
            if elem:IsA("TextButton") and elem ~= elements.crashToggle then
                elem.TextColor3 = Color3.new(1,1,1)
            end
        end
    end
end)

