end)

-- ================= CẬP NHẬT DỮ LIỆU LIÊN TỤC =================
local fps = 0
local lastTime = tick()
local frameCount = 0

RunService.RenderStepped:Connect(function(dt)
    frameCount = frameCount + 1
    local now = tick()
    if now - lastTime >= 1 then
        fps = frameCount
        frameCount = 0
        lastTime = now
    end

    local mem = math.floor(Stats:GetTotalMemoryUsageMb())
    local ping = math.floor(LocalPlayer:GetNetworkPing() * 1000)

    -- Cập nhật icon Auto Crash (chỉ hiển thị, không tương tác)
    crashIcon.Text = autoCrashEnabled and '<font color="#00FF00">✅</font>' or '<font color="#FF0000">❌</font>'
    ramDisplay.Text = string.format("%d/%d", mem, RAM_LIMIT_MB)
    fpsValue.Text = tostring(fps)
    pingValue.Text = tostring(ping)

    -- Responsive font size
    local screenWidth = workspace.CurrentCamera.ViewportSize.X
    local baseSize = math.clamp(math.floor(screenWidth * 0.014), 14, 24)
    for _, elem in pairs(uiElements.labels) do elem.TextSize = baseSize end
    crashIcon.TextSize = baseSize
    ramDisplay.TextSize = baseSize
    fpsValue.TextSize = baseSize
    pingValue.TextSize = baseSize

    -- Rainbow effect (nếu bật)
    if RAINBOW_ENABLED then
        local hue = (tick() % RAINBOW_SPEED) / RAINBOW_SPEED
        local color = HSVtoRGB(hue, 0.9, 1.0)
        for _, elem in pairs(uiElements.labels) do elem.TextColor3 = color end
        ramDisplay.TextColor3 = color
        fpsValue.TextColor3 = color
        pingValue.TextColor3 = color
        -- crashIcon giữ màu riêng
    else
        local white = Color3.new(1,1,1)
        for _, elem in pairs(uiElements.labels) do elem.TextColor3 = white end
        ramDisplay.TextColor3 = white
        fpsValue.TextColor3 = white
        pingValue.TextColor3 = white
    end
end)

-- ================= LOAD EXTERNAL SCRIPT (tuỳ chọn) =================
local function safeLoad(url, name)
    pcall(function()
        local success, result = pcall(game.HttpGet, game, url)
        if success then
            local f = loadstring(result)
            if f then pcall(f) end
        end
    end)
end

