-- Biến UI động
local fps = 0
local last = tick()
local frames = 0
local hueShift = 0

-- Hàm cập nhật text trên thanh
local function updateInfoLabel()
    local mem = math.floor(Stats:GetTotalMemoryUsageMb())
    local ping = math.floor(LocalPlayer:GetNetworkPing() * 1000)
    
    local crashStatus = autoShutdownEnabled and "On" or "Off"
    local ramDisplay = string.format("%d/%d MB", mem, memoryLimitMB)
    local fpsDisplay = fpsLockEnabled and fpsCapValue or "Off"
    local lockCapDisplay = fpsLockEnabled and fpsCapValue or "60"
    
    local text = string.format("%s | %s | ⚠️ Auto crash: %s (%s) | FPS: %d (Lock cap: %s) | Ping: %d ms",
        LocalPlayer.Name,
        deviceType,
        crashStatus,
        ramDisplay,
        fps,
        lockCapDisplay,
        ping
    )
    
    InfoLabel.Text = text
end

-- Xử lý sự kiện click vào InfoLabel để điều khiển (phân vùng)
InfoLabel.InputBegan:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseButton1 then
        local mousePos = UserInputService:GetMouseLocation()
        local guiPos = InfoLabel.AbsolutePosition
        local guiSize = InfoLabel.AbsoluteSize
        local relativeX = (mousePos.X - guiPos.X) / guiSize.X
        
        -- Phân tích vùng click dựa trên text (ước lượng)
        if relativeX >= 0.1 and relativeX <= 0.2 then
            -- Vùng Auto crash (bật/tắt)
            autoShutdownEnabled = not autoShutdownEnabled
            config.autoCrashEnabled = autoShutdownEnabled
            saveConfig()
            notify("Auto Crash", autoShutdownEnabled and "BẬT" or "TẮT", 2)
        elseif relativeX >= 0.25 and relativeX <= 0.4 then
            -- Vùng RAM limit: mở prompt nhập giá trị mới
            local newLimit = tonumber(pcall(function() return game:HttpGet("") end) and "0") -- placeholder for prompt
            -- Sử dụng một thủ thuật: tạo một TextBox ẩn để nhập
            local inputBox = Instance.new("TextBox")
            inputBox.Size = UDim2.new(0, 100, 0, 30)
            inputBox.Position = UDim2.new(0.3, 0, 0.5, -15)
            inputBox.PlaceholderText = "Nhập MB (min 500)"
            inputBox.Text = tostring(memoryLimitMB)
            inputBox.Parent = ScreenGui
            inputBox:CaptureFocus()
            inputBox.FocusLost:Connect(function(enterPressed)
                local val = tonumber(inputBox.Text)
                if val and val >= 500 then
                    memoryLimitMB = val
                    config.ramLimit = val
                    saveConfig()
                    notify("RAM Limit", "Đã đặt "..val.." MB", 2)
                end
                inputBox:Destroy()
            end)
        elseif relativeX >= 0.45 and relativeX <= 0.55 then
            -- Vùng FPS lock: bật/tắt
            fpsLockEnabled = not fpsLockEnabled
            ToggleBtn.Text = fpsLockEnabled and "FPS ON" or "FPS OFF"
            notify("FPS Lock", fpsLockEnabled and "BẬT (cap "..fpsCapValue..")" or "TẮT (60)", 2)
        elseif relativeX >= 0.55 and relativeX <= 0.7 then
            -- Vùng Lock cap value: mở prompt nhập
            local inputBox = Instance.new("TextBox")
            inputBox.Size = UDim2.new(0, 80, 0, 30)
            inputBox.Position = UDim2.new(0.55, 0, 0.5, -15)
            inputBox.PlaceholderText = "FPS Cap"
            inputBox.Text = tostring(fpsCapValue)
            inputBox.Parent = ScreenGui
            inputBox:CaptureFocus()
            inputBox.FocusLost:Connect(function(enterPressed)
                local val = tonumber(inputBox.Text)
                if val and val >= 5 and val <= 60 then
                    fpsCapValue = val
                    config.fpsCap = val
                    saveConfig()
                    notify("FPS Cap", "Đã đặt "..val.." FPS", 2)
                end
                inputBox:Destroy()
            end)
        elseif relativeX >= 0.85 and relativeX <= 0.95 then
            -- Vùng bật/tắt hiệu ứng cầu vồng
            rainbowEnabled = not rainbowEnabled
            config.rainbowEnabled = rainbowEnabled
            saveConfig()
            notify("Rainbow Effect", rainbowEnabled and "BẬT" or "TẮT", 2)
        end
    end
end)

-- Nút toggle FPS (đồng bộ)
ToggleBtn.MouseButton1Click:Connect(function()
    fpsLockEnabled = not fpsLockEnabled
    ToggleBtn.Text = fpsLockEnabled and "FPS ON" or "FPS OFF"
end)

-- ================= CẬP NHẬT LIÊN TỤC =================
RunService.RenderStepped:Connect(function(deltaTime)
    frames = frames + 1
    local now = tick()
    if now - last >= 1 then
        fps = frames
        frames = 0
        last = now
    end
    
    -- Cập nhật màu sắc
    if rainbowEnabled then
        hueShift = (hueShift + deltaTime / rainbowSpeed) % 1
        InfoLabel.TextColor3 = HSVtoRGB(hueShift, 0.9, 1.0)
    else
        InfoLabel.TextColor3 = Color3.new(1, 1, 1)
    end
    
    updateInfoLabel()
end)

